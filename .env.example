# ── E*TRADE OAuth1 ────────────────────────────────────────────────────────────
ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=
ETRADE_SANDBOX=true

# ── Ollama ────────────────────────────────────────────────────────────────────
# On R730 (Docker): http://ollama-gpu0:11434 / http://ollama-gpu1:11435
# On ThinkPad (local dev): http://localhost:11434
OLLAMA_HOST_GPU0=http://ollama-gpu0:11434
OLLAMA_HOST_GPU1=http://ollama-gpu1:11435

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000
# ThinkPad dev: use local path instead of network client
# CHROMA_PATH=./chroma_data

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=/app/biotech_tracker.db
# ThinkPad dev override: DB_PATH=./biotech_tracker.db

# ── SEC EDGAR ─────────────────────────────────────────────────────────────────
# Required User-Agent header for all EDGAR API requests (REQ-081)
SEC_USER_AGENT=biotech-analyzer your@email.com

# ── Output ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=/app/output
# ThinkPad dev override: OUTPUT_DIR=./output
